{
  "name": "tradingview",
  "version": "1.0.0",
  "description": "TradingView Worker authority, shared core package, and agent skill workflows.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm --filter @tradingview/core build && pnpm --filter worker build",
    "typecheck": "pnpm --filter @tradingview/core typecheck && pnpm --filter worker typecheck",
    "test": "pnpm --filter @tradingview/core test && pnpm --filter worker test && pnpm run skill:validate && pnpm run openapi:validate",
    "skill:validate": "node scripts/validate-tradingview-skill.mjs",
    "openapi:validate": "node scripts/validate-worker-openapi.mjs",
    "dev": "pnpm --filter worker dev",
    "deploy": "pnpm --filter worker deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "yaml": "^2.6.0"
  }
}
